{
  "manifest_version": 3,
  "name": "Browser Support Tool",
  "version": "1.0",
  "description": "Simple Chrome extension with a recognizable UI to assist end users with clearing cookies and cache, save screenshots and capture HAR files for troubleshooting",
  "permissions": [
    "cookies",
    "browsingData",
    "storage",
    "debugger",
    "tabs",
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}